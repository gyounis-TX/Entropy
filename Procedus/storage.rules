rules_version = '2';

// Production rules: require Firebase Auth.
// Upload paths: v1/users/{uid}/...
service firebase.storage {
  match /b/{bucket}/o {
    match /v1/users/{uid}/{allPaths=**} {
      // Any authenticated user can read (needed for Teaching Files / shared gallery).
      allow read: if request.auth != null;
      // Only the owning user can write to their own folder.
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Deny everything else.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
